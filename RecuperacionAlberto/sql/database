CREATE TABLE CENTROS_FORENSES (
ID_CENTROS_FORENSES INTEGER NOT NULL,
NOMBRE_CENTRO VARCHAR2(150) NOT NULL,
PAIS VARCHAR2(150) NOT NULL,
NIVEL_SEGURIDAD VARCHAR2(150) NOT NULL,
AUTOR_EXAMEN VARCHAR2(150) NOT NULL,

CONSTRAINT PK_ID_CENTROS_FORENSES PRIMARY KEY(ID_CENTROS_FORENSES),
CONSTRAINT UQ_NOMBRE_CENTRO UNIQUE(NOMBRE_CENTRO),
CONSTRAINT CK_NIVEL_SEGURIDAD CHECK (NIVEL_SEGURIDAD >= 0)
);



CREATE TABLE MUESTRAS_FORENSES (
ID_MUESTRAS_FORENSES INTEGER NOT NULL,
CODIGO_CASO VARCHAR2(150) NOT NULL,
TIPO_MUESTRA VARCHAR2(150) NOT NULL,
FECHA_RECOGIDA DATE NOT NULL,
ESTADO_CUSTODIA VARCHAR2(150) NOT NULL,
ID_CENTROS FORENSES INTEGER NOT NULL,
AUTOR_EXAMEN VARCHAR2(150) NOT NULL,

CONSTRAINT PK_ID_MUESTRAS_FORENSES PRIMARY KEY(ID_MUESTRAS_FORENSES),
CONSTRAINT FK_ID_CENTROS_MUESTRAS
FOREIGN KEY (ID_CENTROS_FORENSES)
REFERENCES CENTROS_FORENSES(ID_CENTROS_FORENSES),
CONSTRAINT UQ_CODIGO_CASO UNIQUE(CODIGO_CASO),
CONSTRAINT UQ_ID_CENTROS_FORENSES UNIQUE(ID_CENTROS_FORENSES)
);


CREATE TABLE INFORMES_FORENSES (
ID_INFORMES_FORENSES INTEGER NOT NULL,
ADN_POSITIVO BOOLEAN NOT NULL,
NIVEL_RIESGO VARCHAR2(150) NOT NULL,
CONCLUSION VARCHAR2(150) NOT NULL,
ID_MUESTRAS_FORENSES INTEGER NOT NULL,
AUTOR_EXAMEN VARCHAR2(150) NOT NULL,

CONSTRAINT PK_ID_INFORMES_FORENSES PRIMARY KEY(ID_INFORMES_FORENSES),
CONSTRAINT FK_ID_MUESTRAS_INFORMES
FOREIGN KEY (ID_MUESTRAS_FORENSES)
REFERENCES MUESTRAS_FORENSES(ID_MUESTRAS_FORENSES),
CONSTRAINT UQ_ID_MUESTRAS_FORENSES UNIQUE(ID_MUESTRAS_FORENSES)
);
