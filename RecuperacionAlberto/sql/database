CREATE TABLE CENTROS_FORENSES (
ID_CENTROS_FORENSES INTEGER NOT NULL,
NOMBRE_CENTRO VARCHAR2(50) NOT NULL,
PAIS VARCHAR2(50) NOT NULL,
NIVEL_SEGURIDAD VARCHAR2(50) NOT NULL,
AUTOR_EXAMEN VARCHAR2(50) NOT NULL,

CONSTRAINT PK_ID_CENTROS_FORENSES PRIMARY KEY(ID_CENTROS_FORENSES),
CONSTRAINT UQ_NOMBRE_CENTRO UNIQUE(NOMBRE_CENTRO),
CONSTRAINT CK_NIVEL_SEGURIDAD CHECK (NIVEL_SEGURIDAD >= 0)
);



