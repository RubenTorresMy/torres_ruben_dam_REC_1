//BUSCAR TODOS LOS CENTROS
SELECT *
FROM CENTROS_FORENSES;

//BUSCAR CENTROS POR NOMBRE
SELECT NOMBRE_CENTRO
FROM CENTROS_FORENSES;

//BUSCAR CENTROS QUE SEAN DE ESPAÑA
SELECT *
FROM CENTROS_FORENSES
WHERE PAIS = 'ESPAÑA';

//BUSCAR TODOS LOS CODIGOS HASH EN LAS MUESTRAS_FORENSES
SELECT *
FROM MUESTRAS_FORENSES
WHERE CODIGO_CASO = 'CODIGO HASH'


//BUSCAR INFORMES CON NIVEL DE RIESGO MAYOR A 90
SELECT *
FROM INFORMES_FORENSES
WHERE NIVEL_RIESGO > 90;